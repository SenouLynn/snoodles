#!/usr/bin/env bash
# SessionStart hook for snoodles plugin
# Injects entry (routing tree) + insights (behavioral rules)

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read skill files
entry_content=$(cat "${PLUGIN_ROOT}/skills/entry/SKILL.md" 2>&1 || echo "Error reading entry skill")
insights_content=$(cat "${PLUGIN_ROOT}/skills/insights/SKILL.md" 2>&1 || echo "Error reading insights skill")

# Read vault config (config.local.json overrides config.json)
vault_path=""
if [[ -f "${PLUGIN_ROOT}/config.local.json" ]]; then
    vault_path=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['vault_path'])" "${PLUGIN_ROOT}/config.local.json" 2>/dev/null || true)
fi
if [[ -z "$vault_path" && -f "${PLUGIN_ROOT}/config.json" ]]; then
    vault_path=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1]))['vault_path'])" "${PLUGIN_ROOT}/config.json" 2>/dev/null || true)
fi

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

entry_escaped=$(escape_for_json "$entry_content")
insights_escaped=$(escape_for_json "$insights_content")

# Build vault context line if vault path was resolved
vault_context=""
if [[ -n "$vault_path" ]]; then
    vault_path_escaped=$(escape_for_json "$vault_path")
    vault_context="\\n---\\nObsidian vault path: ${vault_path_escaped}\\n"
fi

session_context="<EXTREMELY_IMPORTANT>\nYou have snoodles.\n\n${entry_escaped}\n\n---\n\n${insights_escaped}${vault_context}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
# Keep both shapes for compatibility:
# - Cursor hooks expect additional_context.
# - Claude hooks expect hookSpecificOutput.additionalContext.
cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
